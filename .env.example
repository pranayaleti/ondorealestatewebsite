# OndoREui — copy to .env.local and fill in values.

# Stripe Configuration (public — publishable key only)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Supabase Configuration (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable/anon key (use either variable name)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only (NOT prefixed with NEXT_PUBLIC_)
# Supabase service role for API routes
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HubSpot (server-side API route only)
HUBSPOT_ACCESS_TOKEN=pat-na2-your-access-token

# HubSpot tracking script (public — your portal ID)
# Example: if your URL is app.hubspot.com/contacts/12345678, set NEXT_PUBLIC_HUBSPOT_PORTAL_ID=12345678
NEXT_PUBLIC_HUBSPOT_PORTAL_ID=245076632

# Zapier (server-side API route only)
ZAPIER_NEW_LEAD_WEBHOOK=https://hooks.zapier.com/hooks/catch/your-hook-id/
